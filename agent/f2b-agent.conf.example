# /etc/f2b-agent.conf
# Fail2BanEntreprise Agent Configuration
#
# Steps:
#   1. Log in to https://f2b.scopcall.com
#   2. Servers → Register New Server → enter this server's hostname
#   3. Copy the generated token (shown only once)
#   4. Paste it as F2B_API_KEY below

# Dashboard URL (no trailing slash)
F2B_API_URL="https://f2b.scopcall.com"

# Per-server token — generated from dashboard → Servers page
# Uniquely identifies this server. Never share it across servers.
F2B_API_KEY="your-per-server-token-here"

# Sync interval in seconds
F2B_SYNC_INTERVAL=60

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default is WARNING — safe for production. Use INFO or DEBUG only for troubleshooting.
F2B_LOG_LEVEL="WARNING"

# Heartbeat interval in seconds — how often to log a summary to the log file.
# Default is 3600 (1 hour). The agent runs silently between heartbeats
# unless a state change occurs (e.g. API becomes unreachable or recovers).
F2B_HEARTBEAT_INTERVAL=3600

# Ensure sets and rules are created ,before enabling the agent service.
#
# Whitelist (hash:net) — IPs/CIDRs here are skipped from all target sets
F2B_IPSET_WHITELIST_NAME="whitelist"

# Comma-separated per-jail/category sets to maintain (hash:ip):
# Bans with jail=<name> go into that set; otherwise into blacklist.
F2B_IPSET_SETS="ssh,sip,db,web,proxy,email"

# Blacklist (hash:ip) — fallback target when a ban has no matching jail category
F2B_IPSET_BLACKLIST_NAME="blacklist"

